{
  "name": "teams-generator",
  "version": "1.3.0",
  "private": true,
  "description": "Generate teams randomly based on rank. This is useful if you want to create lineups of balanced teams.",
  "type": "module",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "scripts": {
    "clean": "nuxt cleanup && rm -rf node_modules .generated .nuxt",
    "dev": "nuxt dev",
    "start": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "run-s nuxt:prepare db:generate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "pnpm docker:up && playwright test && pnpm docker:down",
    "test:ui": "pnpm docker:up && playwright test --ui && pnpm docker:down",
    "test:dev": "pnpm docker:up && pnpm test:db:reset && nuxt dev --dotenv .env.test",
    "test:db:reset": "dotenv -e .env.test -- zen migrate reset --force",
    "test:build": "nuxt build --dotenv .env.test",
    "test:preview": "nuxt preview --dotenv .env.test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nuxt:prepare": "nuxt prepare",
    "nuxt:build": "nuxt build",
    "db:deploy": "zen migrate deploy",
    "db:generate": "zen generate --lite",
    "db:migrate": "zen migrate dev",
    "playwright": "playwright",
    "dotenv": "dotenv"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.106",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/image": "2.0.0",
    "@pinia/colada-devtools": "1.0.0",
    "@pinia/nuxt": "0.11.3",
    "@playwright/test": "1.60.0",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vite-pwa/nuxt": "1.1.1",
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "@zenstackhq/cli": "3.6.4",
    "dotenv-cli": "11.0.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "npm-run-all2": "8.0.4",
    "nuxt": "4.4.5",
    "pinia": "3.0.4",
    "sharp": "0.34.5",
    "sharp-ico": "0.1.5",
    "std-env": "4.1.0",
    "vue-tsc": "3.2.8"
  },
  "dependencies": {
    "@formwerk/core": "0.14.4",
    "@nuxt/ui": "4.7.1",
    "@pinia/colada": "1.3.0",
    "@pinia/colada-nuxt": "1.0.1",
    "@vueuse/components": "14.3.0",
    "@vueuse/router": "14.3.0",
    "@zenstackhq/orm": "3.6.4",
    "@zenstackhq/plugin-policy": "3.6.4",
    "@zenstackhq/server": "3.6.4",
    "lodash-es": "4.18.1",
    "nuxt-ui-formwerk": "0.1.21",
    "pg": "8.20.0",
    "pg-connection-string": "2.12.0",
    "typescript": "6.0.3",
    "vue-slicksort": "2.0.5",
    "zenstack-pinia-colada": "0.2.7",
    "zod": "4.4.3"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.34.5"
    }
  }
}
